{
  "dataset": {
    "repo_id": "test/sim_demo",
    "root": "/home/qzl/data/sim_demos"
  },
  "policy": {
    "type": "reward_classifier",
    "model_name": "helper2424/resnet10",
    "model_type": "cnn",
    "num_cameras": 1,
    "num_classes": 2,
    "hidden_dim": 256,
    "dropout_rate": 0.1,
    "learning_rate": 1e-4,
    "device": "cuda",
    "use_amp": true,
    "push_to_hub": false,
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      }
    }
  },
  "batch_size": 32,
  "steps": 5000,
  "eval_freq": 500,
  "save_freq": 1000,
  "log_freq": 100,
  "wandb": {
    "enable": true,
    "project": "reward_classifier"
  }
}
