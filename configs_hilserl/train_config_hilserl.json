{
  "policy": {
    "type": "sac",
    "device": "cuda",
    "temperature_init": 0.01,
    "discount": 0.99,
    "target_update_rate": 0.005,
    "actor_lr": 3e-4,
    "critic_lr": 3e-4,
    "alpha_lr": 3e-4,
    "utd_ratio": 20,
    "storage_device": "cuda",
    "actor_learner_config": {
      "policy_parameters_push_frequency": 2.0,
      "learner_host": "localhost",
      "learner_port": 50051
    },
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [7]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [7]
      }
    }
  },
  "env": {
    "type": "gym_manipulator",
    "name": "real_robot",
    "fps": 10,
    "task": "pick_and_lift",
    "processor": {
      "control_mode": "gamepad",
      "observation": {
        "add_joint_velocity_to_observation": false,
        "add_current_to_observation": false,
        "display_cameras": true
      },
      "image_preprocessing": {
        "crop_params_dict": {
          "observation.images.front": [100, 100, 200, 200]
        },
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": 0.0
      },
      "reset": {
        "fixed_reset_joint_positions": [0.0, -45.0, 90.0, 0.0, 45.0, 0.0, 50.0],
        "reset_time_s": 5.0,
        "control_time_s": 20.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": {
        "urdf_path": "path/to/piper.urdf",
        "target_frame_name": "end_effector",
        "end_effector_bounds": {
          "min": [0.15, -0.15, 0.02],
          "max": [0.35, 0.15, 0.2]
        },
        "end_effector_step_sizes": {
          "x": 0.02,
          "y": 0.02,
          "z": 0.02
        }
      },
      "reward_classifier": {
        "pretrained_path": "outputs/reward_classifier/best_model",
        "success_threshold": 0.7,
        "success_reward": 1.0
      }
    },
    "robot": {
      "type": "piper_follower",
      "port": "/dev/ttyUSB0",
      "id": "piper"
    },
    "teleop": {
      "type": "gamepad",
      "use_gripper": true
    }
  },
  "dataset": {
    "repo_id": "your_username/piper_pick_lift",
    "root": "data/demos",
    "task": "pick_and_lift"
  },
  "training": {
    "num_steps": 100000,
    "batch_size": 256,
    "buffer_size": 100000,
    "warmup_steps": 1000,
    "eval_freq": 1000,
    "save_freq": 5000,
    "log_freq": 100
  },
  "wandb": {
    "enable": true,
    "project": "piper-hilserl",
    "entity": null
  },
  "output_dir": "outputs/hilserl_training"
}
