{
  "env": {
    "type": "gym_manipulator",
    "name": "real_robot",
    "fps": 10,
    "task": "pick_and_lift",
    "processor": {
      "control_mode": "gamepad",
      "observation": {
        "add_joint_velocity_to_observation": false,
        "add_current_to_observation": false,
        "display_cameras": true
      },
      "image_preprocessing": {
        "crop_params_dict": {},
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": 0.0
      },
      "reset": {
        "fixed_reset_joint_positions": null,
        "reset_time_s": 5.0,
        "control_time_s": 20.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": {
        "urdf_path": "path/to/piper.urdf",
        "target_frame_name": "end_effector",
        "end_effector_bounds": {
          "min": [-0.5, -0.5, 0.0],
          "max": [0.5, 0.5, 0.5]
        },
        "end_effector_step_sizes": {
          "x": 0.02,
          "y": 0.02,
          "z": 0.02
        }
      },
      "reward_classifier": {
        "pretrained_path": null,
        "success_threshold": 0.5,
        "success_reward": 1.0
      },
      "max_gripper_pos": 100.0
    },
    "robot": {
      "type": "piper_follower",
      "port": "/dev/ttyUSB0",
      "id": "piper"
    },
    "teleop": {
      "type": "gamepad",
      "use_gripper": true
    }
  },
  "dataset": {
    "repo_id": "your_username/piper_pick_lift",
    "root": "data/demos",
    "task": "pick_and_lift",
    "num_episodes_to_record": 15,
    "replay_episode": null,
    "push_to_hub": false
  },
  "mode": "record",
  "device": "cuda"
}
