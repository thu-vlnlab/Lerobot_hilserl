{
  "env": {
    "type": "gym_manipulator",
    "name": "real_robot",
    "fps": 10,
    "task": "pick_and_lift",
    "processor": {
      "control_mode": "gamepad",
      "observation": {
        "add_joint_velocity_to_observation": false,
        "add_current_to_observation": false,
        "display_cameras": true
      },
      "image_preprocessing": {
        "crop_params_dict": {},
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": 0.0
      },
      "reset": {
        "fixed_reset_joint_positions": [0.0, 90.0, -85.0, 0.0, 0.0, 0.0, 35.0],
        "reset_time_s": 5.0,
        "control_time_s": 20.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": {
        "urdf_path": null,
        "target_frame_name": "end_effector",
        "end_effector_bounds": {
          "min": [0.1, -0.2, 0.02],
          "max": [0.4, 0.2, 0.3]
        },
        "end_effector_step_sizes": {
          "x": 0.02,
          "y": 0.02,
          "z": 0.02
        }
      },
      "reward_classifier": {
        "pretrained_path": null,
        "success_threshold": 0.5,
        "success_reward": 1.0
      },
      "max_gripper_pos": 70.0
    },
    "robot": {
      "type": "piper_follower",
      "can_name": "can0",
      "id": "piper_arm",
      "use_degrees": true,
      "cameras": {
        "observation.images.front": {
          "type": "opencv",
          "index_or_path": 0,
          "width": 640,
          "height": 480,
          "fps": 30
        }
      }
    },
    "teleop": {
      "type": "gamepad",
      "use_gripper": true
    }
  },
  "dataset": {
    "repo_id": "thu-vlnlab/piper_pick_lift",
    "root": "data/demos",
    "task": "pick_and_lift",
    "num_episodes_to_record": 15,
    "replay_episode": null,
    "push_to_hub": false
  },
  "mode": "record",
  "device": "cuda"
}
