{
  "output_dir": "outputs/train_hilserl_piper_real_v4",
  "resume": false,
  "batch_size": 64,
  "save_checkpoint": true,
  "save_freq": 500,
  "policy": {
    "type": "sac",
    "push_to_hub": false,
    "device": "cuda",
    "temperature_init": 0.01,
    "discount": 0.99,
    "critic_target_update_weight": 0.005,
    "actor_lr": 3e-4,
    "critic_lr": 1e-4,
    "temperature_lr": 3e-4,
    "utd_ratio": 20,
    "num_critics": 10,
    "num_subsample_critics": 2,
    "storage_device": "cuda",
    "online_buffer_capacity": 100000,
    "offline_buffer_capacity": 30000,
    "actor_learner_config": {
      "policy_parameters_push_frequency": 2,
      "learner_host": "localhost",
      "learner_port": 50051
    },
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [6]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [3]
      }
    }
  },
  "env": {
    "type": "gym_manipulator",
    "name": "real_robot",
    "fps": 10,
    "task": "pick_and_lift",
    "features": {
      "action": {
        "type": "ACTION",
        "shape": [3]
      },
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [3, 128, 128]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [6]
      }
    },
    "features_map": {
      "action": "action",
      "observation.images.front": "observation.images.front",
      "observation.state": "observation.state"
    },
    "processor": {
      "control_mode": "gamepad",
      "observation": {
        "add_joint_velocity_to_observation": false,
        "add_current_to_observation": false,
        "display_cameras": true
      },
      "image_preprocessing": {
        "crop_params_dict": {},
        "resize_size": [128, 128]
      },
      "gripper": {
        "use_gripper": false,
        "gripper_penalty": 0.0
      },
      "reset": {
        "fixed_reset_joint_positions": [0, 77.14, -57.0, 0, 77.73, 0, 0.0],
        "reset_time_s": 5.0,
        "control_time_s": 15.0,
        "terminate_on_success": true
      },
      "inverse_kinematics": null,
      "reward_classifier": {
        "pretrained_path": "outputs/reward_classifier_piperv3merge/checkpoints/last/pretrained_model",
        "success_threshold": 0.85,
        "success_reward": 1.0,
        "position_constraint": {
          "x_min": 0.20,
          "x_max": 0.40,
          "y_min": -0.10,
          "y_max": 0.10,
          "z_min": 0.10,
          "z_max": 0.25
        }
      },
      "max_gripper_pos": 70.0
    },
    "robot": {
      "type": "piper_follower_ee",
      "can_name": "can0",
      "id": "piper_arm",
      "use_degrees": true,
      "cameras": {
        "front": {
          "type": "intelrealsense",
          "serial_number_or_name": "338622070324",
          "width": 640,
          "height": 480,
          "fps": 30
        }
      }
    },
    "teleop": {
      "type": "gamepad",
      "use_gripper": false
    }
  },
  "dataset": {
    "repo_id": "piper_pick_lift_v4",
    "root": "data/expert_demosv4"
  },
  "wandb": {
    "enable": true,
    "project": "piper-hilserl-real-v4",
    "entity": null
  }
}
